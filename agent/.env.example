# Copy to .env and fill in. The agent reads these at startup.

# Model provider: vllm | openai | anthropic. The agent is built for self-hosted vLLM.
MODEL_PROVIDER=vllm

# Self-hosted vLLM, OpenAI-compatible. Point at your Akamai GPU endpoint.
VLLM_BASE_URL=http://your-vllm-endpoint/v1
VLLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
VLLM_API_KEY=placeholder

# Anthropic API. Set MODEL_PROVIDER=anthropic to run with no GPU (single Linode).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-5-20250929

# Read-only Linode API token. The account reads use it.
LINODE_TOKEN=

# Account reads come from the akamai-cloud-mcp server.
MCP_ENABLED=true

# The documentation specialist's local Akamai docs index.
DOCS_INDEX_PATH=./data/llms.txt

# Sessions: memory (in process) | file | s3 (Akamai Object Storage).
SESSION_BACKEND=memory
SESSION_BUCKET=
SESSION_CLUSTER=
SESSION_ACCESS_KEY=
SESSION_SECRET_KEY=

# Discord bridge, optional. This is the Bot token (Developer Portal -> your app ->
# Bot -> Reset Token). The OAuth2 invite URL is not set here; you open that URL
# once in a browser to add the bot. See docs/discord-integration.md.
DISCORD_TOKEN=

# Optional. Your server (guild) id, so slash commands register instantly. Enable
# Developer Mode in Discord, right-click the server, Copy Server ID. Leave blank to
# sync globally (can take up to an hour to appear).
DISCORD_GUILD_ID=

# Telemetry, optional (Langfuse).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Long-term memory, optional. Akamai Managed PostgreSQL connection string. When
# unset, the agent runs on sessions alone (no durable facts).
DATABASE_URL=
